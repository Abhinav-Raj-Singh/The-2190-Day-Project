#include <iostream>

int main(){

	// By implicit cast conversion

	double x{16.7};
	double y{13.89};

	int sum = x + y; 
	std::cout << "The sum is : " << sum << std::endl;

	// Explicitly casting 

	sum = static_cast<int>(x) + static_cast<int>(y) ;

	std::cout << "The sum is : " << sum << std::endl;

	// First summing up and then explicitly casting .

	sum = static_cast<int>(x+y);
	std::cout << "The sum is : " << sum << std::endl;

	// Old c - style conversion
	double PI {3.14};

	int int_pi = (int)(PI);
	std::cout << "PI is : " << PI << std::endl;
	std::cout << "PI in int_pi form is : " << int_pi << std::endl;

	return 0;
}
