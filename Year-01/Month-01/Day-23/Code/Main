#include <iostream>

int main(){

    // Literals types : l and u are used for long and unsigned .
    unsigned char unsigned_char{55u}; // 555u will throw error

    // 2 Bytes
    short short_var{-1234}; // no special literal type for short
    short int short_int{455};
    signed short signed_short{245};
    signed short int signed_short_int {465};
    unsigned short int unsigned_short_int{4569U};

    // 4 Bytes
    const int int_var{45};
    signed signed_var{345};
    signed int signed_int{3456};
    unsigned int unsigned_int{34567u};

    // 4 or 8 bytes
    long long_var{3456l}; // 4 or 8 bytes 
    long int long_int { 234678l };
    signed long signed_long{4893l};
    signed long int signed_long_int{7896l};
    unsigned long int unsigned_long_int{5646};

    long long long_long{13657ll};
    long long int long_long_int{23574567ll};
    signed long long signed_long_long{536537ll};
    signed long long int signed_long_long_int{735677578ll};

    // grouping numbers : c++14 and ownwards
    unsigned int prize{5'00'000u};
    std::cout << "Prize is : " << prize << std::endl;
    std::cout << " signed_long_long_int is : " <<  signed_long_long_int << std::endl;

    // Narrowing errors : mostly we get them when we are trying to store something that is exceeding our limit of that data type and () or = can't catch error and this is dangerous only {} can catch error.
    // unsigned char distance{555u}; // Error[0~255]
    // unsigned int game_score{-22}; // Error
    
    // With number system 0x is the prefix for hex 
    unsigned int hex_number1{0x22BU}; // Dec 555
    int hex_number2{0x400}; // Dec 1024
    std::cout << std::hex << "hex_number1 : " << hex_number1 << std::endl;
    std::cout << std::dec << "hex_number2 : " << hex_number2 << std::endl;

    // Representing colours with hex
    int black_colour{0xffffff};
    std::cout << "black_colour is : " << black_colour << std::endl;

    // Octal literals : prefix with 0 
    int octal_number{0777u}; // 511 dec
   std::cout << "The octal_number is : " << octal_number << std::endl;
   // !!Be careful not to prefix your integers with 0 if you mean decimal
   int error_octal {055}; // This is not 55 in memory it is 45 in decimal
   std::cout << "The erronous octal number : " << error_octal << std::endl;
   
   // Binary literals : with prefix 0b

   unsigned int binary_literal {0b11111111u}; // 255 dec 
   std::cout << "The binary literal is : " << binary_literal << std::endl;

   char char_litearl{'c'};
   int number_literal{15};
   float float_literal{1.5f};
   std::string string_literal{"You won!"};

   std::cout << "char_literal is : " << char_litearl << std::endl;
   std::cout << "number_literal is : " << number_literal << std::endl;
   std::cout << "float_literal is : " << float_literal << std::endl;
   std::cout << "string_literal is : " << string_literal << std::endl;
    return 0 ;
}
