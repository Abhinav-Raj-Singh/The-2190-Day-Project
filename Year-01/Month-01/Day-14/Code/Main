#include <iostream>

int main(){
    int var1{123}; // Declare & initialize
    std::cout << "var1 is " << var1 << std::endl;
    
    var1 = 55; // Assign
    std::cout << "var2 is " << var1 << std::endl;

    std::cout << std::endl;
    std::cout << "----------------------" << std::endl;

    double var2{44.55}; // Declare & initialize 
    std::cout << "var2 is " << var2 << std::endl;

    var2 = 99.99;
    std::cout << "var2 is " << var2 << std::endl;

    std::cout << std::endl;
    std::cout << "----------------------" << std::endl;

    bool state{false}; // Declare & initialize 
    std::cout << std::boolalpha;
    std::cout << "State : " << state << std::endl;

    state = true; // Assign
    std::cout << "State : " << state << std::endl; 
    
    std::cout << std::endl;
    std::cout << "----------------------" << std::endl;
    
    // Auto type deduction 
    // Be careful while dealing with auto type .

    auto var3{333u} ; // Declare & initialize with type deduction.
    std::cout << "var3 : " << var3 << std::endl;
    
    var3 = -22 ; 
    std::cout << "var3 : " << var3 << std::endl;

    

    return 0;
}
