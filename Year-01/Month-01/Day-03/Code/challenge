/* Small challenge by tutor 
Q. Make function which take two numbers as parameters 
and return their multiplication and use it in main function?
*/

int product(int first_number , int second_number){
    
    int result = first_number * second_number ;
    return result;
}

# include <iostream>

int main(){
    
     
    int output = product(5,7);

    std::cout << "Product :" << output << std::endl;
    
    return 0;
}
