/*
Write a program that reads in the length and width and height of a box and computes the base area and volume using the following formulas:

base_area = width * length
volume = base_area * height

*/

#include <iostream>

int main(){

    double length{};
    double width{};
    double height{};

    std::cout << "Welcome to box calculator please type in length , width and height  : " << std::endl;

    std::cout << "lenght " ;
    std::cin >> length;
    std::cout << "width " ;
    std::cin >> width;
    std::cout << "height " ;
    std::cin >> height;
    

    double base_area{length * width};
    double volume{length * width * height};

    std::cout << "base area of box is : " << base_area << std::endl;
    std::cout << "volume of box is : " << volume << std::endl;
    

    return 0 ;
}
