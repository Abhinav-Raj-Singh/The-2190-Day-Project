#include <iostream>

int main(){

	double price{38.5};
	int units{10};

	auto total_price = units*price; // Our units variable is implicitly converted from int type to double type

	std::cout << "total_price : "  << total_price << std::endl;
	std::cout << "sizeof(total_price) : " << sizeof(total_price) << std::endl;

	int x;
	double y {25.4};

	x = y; // Going from right to left that is from dobule to int
	std::cout << "value of x : " << x << std::endl;
	std::cout << "sizeof(x) : " << sizeof(x) << std::endl;

	return 0;
}
