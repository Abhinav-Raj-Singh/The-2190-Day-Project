#include <iostream>
#include <bitset>
#include <iomanip>

int main(){

    int column_width{20};
    unsigned char value1 {0x3};
    unsigned char value2 {0x5};

    std::cout << std::setw(column_width) << "value1 : " << std::setw(column_width) << std::bitset<8>(value1) << std::endl;
    std::cout << std::setw(column_width) << "value2 : " << std::setw(column_width) << std::bitset<8>(value2) << std::endl;
    
    // And 

    std::cout << std::endl;
    std::cout << "Bitwise And : " << std::endl;
    std::cout << std::setw(column_width) << "value1 & value2 is : " << std::setw(column_width) << std::bitset<8>(value1&value2) << std::endl;
    
    // OR
    std::cout << std::endl;
    std::cout << "Bitwise Or : " << std::endl;
    std::cout << std::setw(column_width) << "value1 | value2" << std::setw(column_width) << std::bitset<8>(value1 | value2) << std::endl;

    // Not 
    std::cout << std::endl;
    std::cout << std::setw(column_width) << "~value1" << std::setw(column_width) << std::bitset<8>(~value1) << std::endl;
    std::cout << std::setw(column_width) << "~value2" << std::setw(column_width) << std::bitset<8>(~value2) << std::endl;

    // Flipping off a literal value using Not operator
    std::cout << std::endl;
    std::cout << std::setw(column_width) << "~00000011" << std::setw(column_width) << std::bitset<8>(~0b00000011) << std::endl;
    std::cout << std::setw(column_width) << "~00000101" << std::setw(column_width) << std::bitset<8>(~0b00000101) << std::endl;
    
    // XOR
    std::cout << std::endl;
    std::cout << "Bitwise XOR : " << std::endl;
    std::cout << std::setw(column_width) << "value1 ^ value2 : " << std::setw(column_width) << std::bitset<8>(value1 ^ value2) << std::endl;
    
    return 0; 
    
}
