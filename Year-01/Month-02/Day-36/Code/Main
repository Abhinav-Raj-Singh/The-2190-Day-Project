#include <iostream>

int main(){
     
    const unsigned int red_mask{0xFF000000};
    const unsigned int green_mask{0x00FF0000};
    const unsigned int blue_mask{0x0000FF00};
    const unsigned int alpha_mask{0x000000FF};
    
    unsigned int my_colour{0XAABCDE00};
    
    std::cout << std::showbase << std::hex;
    std::cout << "Red is : " << ((my_colour & red_mask) >> 24) << std::endl;
    std::cout << "Green is : " << ((my_colour & green_mask) >> 16 ) << std::endl;
    std::cout << "Blue is : " << ((my_colour & blue_mask) >> 8 ) << std::endl;
    std::cout << "Alpha is : " << ((my_colour & alpha_mask) >> 0 ) << std::endl;
    
    // Colours in decimal format
    std::cout << std::endl;
    std::cout <<  std::dec ;
    std::cout << "Red is : " << ((my_colour & red_mask) >> 24) << std::endl;
    std::cout << "Green is : " << ((my_colour & green_mask) >> 16 ) << std::endl;
    std::cout << "Blue is : " << ((my_colour & blue_mask) >> 8 ) << std::endl;
    std::cout << "Alpha is : " << ((my_colour & alpha_mask) >> 0 ) << std::endl;
    return 0;
}
